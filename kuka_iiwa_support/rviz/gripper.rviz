                            wsg_50_base_link:
                              wsg_50_gripper_left:
                                wsg_50_finger_left:
                                  {}
                              wsg_50_gripper_right:
                                wsg_50_finger_right:
                                  {}
      Update Interval: 0
      Value: true
  Enabled: true
  Global Options:
    Background Color: 48; 48; 48
    Default Light: true
    Fixed Frame: world
    Frame Rate: 30
  Name: root
  Tools:
    - Class: rviz/Interact
